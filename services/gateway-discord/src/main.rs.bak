// Welcome Handler — THE COOLEST IN THE WORLD 🔥
// ---------------------------------------------------------------------------

struct WelcomeHandler;

#[async_trait]
impl EventHandler for WelcomeHandler {
    async fn guild_member_addition(&self, ctx: Context, member: Member) {
        // Auto-assign member role
        if let Ok(roles) = member.guild_id.roles(&ctx.http).await {
            if let Some(role) = roles.values().find(|r| r.name == "สมาชิก") {
                let _ = member.add_role(&ctx.http, role.id).await;
            }
        }

        let member_count = member
            .guild_id
            .members(&ctx.http, None, None)
            .await
            .map(|m| m.len())
            .unwrap_or(0);

        let avatar = member
            .user
            .avatar_url()
            .unwrap_or_else(|| member.user.default_avatar_url());

        let username = &member.user.name;
        let mention = member.mention();

        // ════════════════════════════════════════
        // 🌟 MESSAGE 1: THE GRAND ENTRANCE
        // ════════════════════════════════════════
        tokio::time::sleep(Duration::from_millis(300)).await;

        let entrance_embed = CreateEmbed::new()
            .title("🌟 ▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬ ▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬ 🌟")
            .description(format!(
                "## 🚨 **BREAKING NEWS: ส้เลมีคนใหม่เข้าเซิร์ฟววว!** 🚨\n\
                 \n> ### 🎊 **ยินดีด้วย {}!**\n\
                 > คุณได้ข้ามมิติมาเยือน **สถานที่ที่แม่งมันพิลึกที่สุดในจักรวาล**\n\
                 > *สวรรค์ของพวกปากหมา และ สันดานเสีย...*\n\
                 \n> 👤 **ชื่อบนแผนที่:** `{}`\n\
                 > 🆔 **รหัสประจำตัว:** `{}`\n\
                 > 👥 **ลำดับผู้กล้าที่เข้ามา:** **#{}**\n\
                 > 📅 **วันที่ประวัติศาสตร์บันทึก:** {}",
                mention, username, member.user.id, member_count,
                Utc::now().format("%d/%m/%Y %H:%M")
            ))
            .color(0xFF4500u32) // OrangeRed
            .thumbnail(&avatar)
            .image("https://media.giphy.com/media/26ufdipQqU2lhNA4g/giphy.gif")
            .footer(CreateEmbedFooter::new("🔥 Welcome to the Madness — Population: The Brave 🔥"))
            .timestamp(Timestamp::now());

        let _ = ChannelId::new(WELCOME_CHANNEL)
            .send_message(&ctx.http, CreateMessage::new().add_embed(entrance_embed))
            .await;

        // ════════════════════════════════════════
        // ⚔️ MESSAGE 2: THE LAW & THE LEGENDS
        // ════════════════════════════════════════
        tokio::time::sleep(Duration::from_millis(500)).await;

        let law_embed = CreateEmbed::new()
            .title("⚔️ 📜 กฎหมายบ้านเมือง — อ่านให้จบไอ้เวร! 📜 ⚔️")
            .description(
                "**⚠️ คำเตือนประจำสถานที่แห่งนี้:**\n\
                 \n🔴 **ข้อ 1:** ห้ามพิมพ์ *\"สวัสดีครับ\"* — เดี๋ยวบอทกินนะเว้ย\n\
                 🔴 **ข้อ 2:** ถ้าอยู่รอด 7 วัน คุณคือ **ตำนาน**\n\
                 🔴 **ข้อ 3:** `ไอ้เปรม` คือเจ้าถิ่น — **ระวังให้ดี:**\n\
                 > 🐕 มันชอบกินหมา (จริงๆ นะ)\n\
                 > 💊 มันติดยา (ขั้นโคตร)\n\
                 > 😈 มันกามโคตรๆ (ห้ามแหย่)\n\
                 > 🎮 *ถ้าเจอมัน ให้วิ่งหนี... หรือสู้จนตาย* 💀\n\
                 \n━━━━━━━━━━━━━━━━━━━━━━━━\n\
                 \n🎭 **บอทประจำสถาบัน (ขอต้อนรับสู่ความบ้ากบาน):**\n\
                 > 🤖 `ต๊ะ` — วัยรุ่นทรงเอ ปากหมา เกรียนเห็ด\n\
                 > 🍑 `อาวัง` — หนุ่มใหญ่สายหื่น กะล่อนเจ้าชู้\n\
                 > 💃 `เจ๊มุ่ง` — หญิงสาวหิวผู้ชาย ซ้อสายเปย์\n\
                 > 💰 `เสี่ยหนู` — มหาเศรษฐีจอมโอ้อวด หึหึ\n\
                 > 🖤 `โยฮัน` — บอสใหญ่สายดาร์ก จอมบงการ\n\
                 > 🕵️ `ผู้คุมกฎ` — ล่าผู้ฝ่าฝืนสถิติ\n\
                 > 👮 `สารวัตรแจ๊ะ` — ผู้พิพากษา Economy/RPG"
            )
            .color(0x8B00FFu32) // Deep magenta
            .thumbnail("https://media.giphy.com/media/l0HlPw8PkGmZaKvS0/giphy.gif")
            .image("https://media.giphy.com/media/13HBDTkt6XFjvm/giphy.gif")
            .footer(CreateEmbedFooter::new(format!("👥 สมาชิกทั้งหมด: {} คน — คนที่ {} กำลังจะตาย! 💀", member_count, member_count)))
            .timestamp(Timestamp::now());

        let _ = ChannelId::new(WELCOME_CHANNEL)
            .send_message(&ctx.http, CreateMessage::new().add_embed(law_embed))
            .await;

        // ════════════════════════════════════════
        // 🏆 MESSAGE 3: THE ULTIMATE CHALLENGE
        // ════════════════════════════════════════
        tokio::time::sleep(Duration::from_millis(500)).await;

        let challenge_embed = CreateEmbed::new()
            .title("🏆 ⚡ ภารกิจของนักรบผู้กล้า: พิสูจน์ตัวเอง! ⚡ 🏆")
            .description(format!(
                "### 🎯 **{}** เร้าทายนักรบคนใหม่ให้พิสูจน์ตัวเอง:\n\
                 \n**🗡️ ภารกิจที่ 1:** ลองพิมพ์หา `ต๊ะ` แล้วคุณจะรู้จักคำว่า *\"ปากหมา\"*\n\
                 **🛏️ ภารกิจที่ 2:** ไปหา `อาวัง` ที่ห้องนอน... *(ถ้าคุณอายุ 18+)*\n\
                 **💰 ภารกิจที่ 3:** หา `เสี่ยหนู` เพื่อขอเงิน *(เดี๋ยวเขาว่าเออ...)*\n\
                 **💀 ภารกิจลับ:** เจอ `ไอ้เปรม` แล้วรอดชีวิต *(รางวัล: ตำนาน)*\n\
                 \n━━━━━━━━━━━━━━━━━━━━━━━━\n\
                 \n### 🚀 **อย่ารอช้า! เริ่มต้นผจญภัยเลย:**\n\
                 > `/balance` — เช็คยอดเงินในกระเป๋า (ถ้ามี)\n\
                 > `/work` — เริ่มต้นหาเงิน (งานเหี้ยมีให้ทำ)\n\
                 > `!นินทา @ใครซักคน` — นินทาให้บอทฟัง\n\
                 > คุยกับบอททุกตัว — แล้วดูว่าจะบ้าหรือตายก่อน?\n\
                 \n🎊 **ยินดีต้อนรับสู่สวรรค์ของพวกสันดานเสีย...**\n\
                 **ขอให้โชคดี คุณจะต้องการมัน!** 🎊"
            , mention))
            .color(0x00FF00u32) // Lime green
            .image("https://media.giphy.com/media/26gscNQHswqmv6cP6/giphy.gif")
            .thumbnail(&avatar)
            .footer(CreateEmbedFooter::new("🎮 'ตายแล้วเกิดใหม่ก็ได้' — คำกล่าวของตำนานรุ่นพี่ 🎮"))
            .timestamp(Timestamp::now());

        let _ = ChannelId::new(WELCOME_CHANNEL)
            .send_message(&ctx.http, CreateMessage::new().add_embed(challenge_embed))
            .await;

        // ════════════════════════════════════════
        // 🎬 MESSAGE 4: THE FINAL CINEMATIC
        // ════════════════════════════════════════
        tokio::time::sleep(Duration::from_millis(700)).await;

        let finale_embed = CreateEmbed::new()
            .title("🎬 ▬▬▬ 'The Beginning of a Legend' ▬▬▬ 🎬")
            .description(format!(
                "*\"./start --new_legend={} --difficulty=HARD --survival_chance=0.01%\"*\n\
                 \n> 🎲 **RNG Status:** บอททั้ง 7 ตัว จ้องมองคุณอยู่...\n\
                 > 🔥 **Danger Level:** ★★★★★ (MAXIMUM CHAOS)\n\
                 > 💀 **Survival Tip:** อย่าเจอไอ้เปรม\n\
                 \n**{}** *การเดินทางของคุณเริ่มแล้ว...*\n\
                 *ขอให้โชคดีในสถานที่แห่งนี้!* 🍀"
            , username, mention))
            .color(0xFFD700u32) // Gold
            .image("https://media.giphy.com/media/3o7btPCcdNniyqs9qE/giphy.gif")
            .footer(CreateEmbedFooter::new("🌌 'Every legend was once a newcomer' 🌌"))
            .timestamp(Timestamp::now());

        let _ = ChannelId::new(WELCOME_CHANNEL)
            .send_message(&ctx.http, CreateMessage::new().add_embed(finale_embed))
            .await;
    }

    async fn ready(&self, _: Context, ready: Ready) {
        println!("🎬 WelcomeBot [THE COOLEST IN THE WORLD] {} ออนไลน์! (4-Message Cinematic Experience)", ready.user.name);
    }
}
struct InspectorHandler {
    app: Arc<AppState>,
    bot_name: &'static str,
}

impl InspectorHandler {
    fn insp_embed() -> CreateEmbed {
        CreateEmbed::new()
            .color(INSPECTOR_COLOR)
            .footer(CreateEmbedFooter::new("สารวัตรแจ๊ะ – ตำรวจคาบเส้น"))
    }
}

#[async_trait]
impl EventHandler for InspectorHandler {
    async fn message(&self, _: Context, _: Message) {}

    async fn interaction_create(&self, ctx: Context, interaction: Interaction) {
        if let Interaction::Command(cmd) = interaction {
            if cmd.channel_id.get() != INSPECTOR_CMD_CHANNEL {
                let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                    CreateInteractionResponseMessage::new()
                        .content("ใช้ในห้อง <#1501082220172153004> เท่านั้น")
                        .ephemeral(true)
                )).await;
                return;
            }

            match cmd.data.name.as_str() {
                "balance" => {
                    let uid = cmd.user.id.to_string();
                    let r = self.app.ai.clone().get_economy(GetEconomyRequest {
                        user_id: uid.clone().into(),
                    }).await;
                    let embed = if let Ok(resp) = r {
                        let data_json = resp.into_inner().data_json;
                        let wallet = serde_json::from_str::<serde_json::Value>(&data_json)
                            .ok()
                            .and_then(|v| v.get("wallet").and_then(|w| w.as_i64()))
                            .unwrap_or(0);
                        Self::insp_embed()
                            .title("💰 กระเป๋าเงินของมึง")
                            .description(format!("ยอดเงิน: **{}** บาท", wallet))
                    } else {
                        Self::insp_embed()
                            .title("💰 กระเป๋าเงินของมึง")
                            .description("ใช้ /work เพื่อเริ่มทำงาน")
                    };
                    let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                        CreateInteractionResponseMessage::new().add_embed(embed)
                    )).await;
                }
                "work" => {
                    let uid = cmd.user.id.to_string();
                    let r = self.app.ai.clone().get_economy(GetEconomyRequest {
                        user_id: uid.clone().into(),
                    }).await;
                    if let Ok(resp) = r {
                        let data_json = resp.into_inner().data_json;
                        let doc = match serde_json::from_str::<serde_json::Value>(&data_json) {
                            Ok(v) => v,
                            Err(_) => serde_json::json!({}),
                        };
                        let now = Utc::now().timestamp();
                        let last = doc.get("job_last_used").and_then(|v| v.as_i64()).unwrap_or(0);
                        if now - last < 60 {
                            let left = 60 - (now - last);
                            let embed = Self::insp_embed()
                                .title("⏳ ใจเย็น")
                                .description(format!("รออีก **{}** วิ", left));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        } else {
                            let earn = 100 + (now % 101) as i64;
                            let new_wallet = doc.get("wallet").and_then(|v| v.as_i64()).unwrap_or(0) + earn;
                            let data = serde_json::to_string(&serde_json::json!({
                                "user_id": uid,
                                "wallet": new_wallet,
                                "job_last_used": now
                            })).unwrap();
                            let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest {
                                user_id: cmd.user.id.to_string(),
                                username: cmd.user.name.clone(),
                                data_json: data,
                            }).await;
                            let jobs = ["เก็บขยะ", "ส่งของ", "ล้างจาน", "ฝ้าผับ", "รับจ้างด่า"];
                            let job = jobs[(now as usize) % jobs.len()];
                            let embed = Self::insp_embed()
                                .title("🛠️ ทำงาน")
                                .description(format!("มึงไป{}มา ได้เงิน **{}** บาท", job, earn));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        }
                    }
                }
                "crime" => {
                    let uid = cmd.user.id.to_string();
                    let r = self.app.ai.clone().get_economy(GetEconomyRequest {
                        user_id: uid.clone().into(),
                    }).await;
                    let now = Utc::now().timestamp();
                    if let Ok(resp) = r {
                        let data_json = resp.into_inner().data_json;
                        let doc = match serde_json::from_str::<serde_json::Value>(&data_json) {
                            Ok(v) => v,
                            Err(_) => serde_json::json!({}),
                        };
                        let last = doc.get("crime_last_used").and_then(|v| v.as_i64()).unwrap_or(0);
                        let jail_until = doc.get("jail_until").and_then(|v| v.as_i64()).unwrap_or(0);
                        if jail_until > now {
                            let left = jail_until - now;
                            let embed = Self::insp_embed()
                                .title("🔒 มึงติดคุกอยู่!")
                                .description(format!("รออีก **{}** วิ แล้วใช้ /bribe จ่ายสินบนออกมาด่วน", left));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        } else if now - last < 60 {
                            let left = 60 - (now - last);
                            let embed = Self::insp_embed()
                                .title("⏳ ใจเย็น")
                                .description(format!("รออีก **{}** วิ ก่อนก่ออาชญากรรมต่อ", left));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        } else {
                            let success = (now % 100) < 60;
                            let wallet = doc.get("wallet").and_then(|v| v.as_i64()).unwrap_or(0);
                            if success {
                                let earn = 200 + (now % 301) as i64;
                                let new_wallet = wallet + earn;
                                let data = serde_json::to_string(&serde_json::json!({
                                    "user_id": uid,
                                    "wallet": new_wallet,
                                    "crime_last_used": now
                                })).unwrap();
                                let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest {
                                    user_id: cmd.user.id.to_string(),
                                    username: cmd.user.name.clone(),
                                    data_json: data,
                                }).await;
                                let embed = Self::insp_embed()
                                    .title("🎯 ก่ออาชญากรรมสำเร็จ!")
                                    .description(format!("มึงทำมาได้ **{}** บาท เงินรวม: **{}** บาท", earn, new_wallet));
                                let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                    CreateInteractionResponseMessage::new().add_embed(embed)
                                )).await;
                            } else {
                                let fine = 100 + (now % 201) as i64;
                                let new_wallet = (wallet - fine).max(0);
                                let jail_time = now + 600;
                                let data = serde_json::to_string(&serde_json::json!({
                                    "user_id": uid,
                                    "wallet": new_wallet,
                                    "crime_last_used": now,
                                    "jail_until": jail_time
                                })).unwrap();
                                let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest {
                                    user_id: cmd.user.id.to_string(),
                                    username: cmd.user.name.clone(),
                                    data_json: data,
                                }).await;
                                let embed = Self::insp_embed()
                                    .title("💀 มึงโดนจับ!")
                                    .description(format!("โดนปรับ **{}** บาท และติดคุก 10 นาที (เงินเหลือ: **{}**)", fine, new_wallet));
                                let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                    CreateInteractionResponseMessage::new().add_embed(embed)
                                )).await;
                            }
                        }
                    }
                }
                "rob" => {
                    let uid = cmd.user.id.to_string();
                    let now = Utc::now().timestamp();
                    let target_user = cmd.data.options.iter().find_map(|o| {
                        if o.name == "target" { o.value.as_user_id() } else { None }
                    });
                    let amount = cmd.data.options.iter().find_map(|o| {
                        if o.name == "amount" { o.value.as_i64() } else { None }
                    }).unwrap_or(0);
                    let Some(target_id) = target_user else {
                        let embed = Self::insp_embed().title("❌ ผิดพลาด").description("ต้องระบุเป้าหมาย");
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                        return;
                    };
                    let tid = target_id.to_string();
                    let r_me = self.app.ai.clone().get_economy(GetEconomyRequest { user_id: uid.clone().into() }).await;
                    let r_target = self.app.ai.clone().get_economy(GetEconomyRequest { user_id: tid.clone() }).await;
                    if let (Ok(me_resp), Ok(target_resp)) = (r_me, r_target) {
                        let me_doc = serde_json::from_str::<serde_json::Value>(&me_resp.into_inner().data_json).ok();
                        let target_doc = serde_json::from_str::<serde_json::Value>(&target_resp.into_inner().data_json).ok();
                        let last = me_doc.as_ref().and_then(|v| v.get("rob_last_used").and_then(|v| v.as_i64())).unwrap_or(0);
                        if now - last < 300 {
                            let left = 300 - (now - last);
                            let embed = Self::insp_embed().title("⏳ ใจเย็น").description(format!("รออีก **{}** วิ ก่อนปล้นครั้งถัดไป", left));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        let target_wallet = target_doc.as_ref().and_then(|v| v.get("wallet").and_then(|w| w.as_i64())).unwrap_or(0);
                        let my_wallet = me_doc.as_ref().and_then(|v| v.get("wallet").and_then(|w| w.as_i64())).unwrap_or(0);
                        let steal = if amount > 0 { amount.min(target_wallet) } else { (target_wallet as f64 * 0.3) as i64 };
                        let success = (now % 100) < 70;
                        if success {
                            let new_my = my_wallet + steal;
                            let new_target = target_wallet - steal;
                            let data_me = serde_json::to_string(&serde_json::json!({"user_id": uid, "wallet": new_my, "rob_last_used": now})).unwrap();
                            let data_target = serde_json::to_string(&serde_json::json!({"user_id": tid, "wallet": new_target})).unwrap();
                            let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest { user_id: cmd.user.id.to_string(), username: cmd.user.name.clone(), data_json: data_me }).await;
                            let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest { user_id: target_id.to_string(), username: target_id.to_string(), data_json: data_target }).await;
                            let embed = Self::insp_embed().title("💰 ปล้นสำเร็จ!").description(format!("มึงปล้นไปได้ **{}** บาท! (ตอนนี้มี: **{}**)", steal, new_my));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        } else {
                            let fine = steal / 2;
                            let new_my = (my_wallet - fine).max(0);
                            let data_me = serde_json::to_string(&serde_json::json!({"user_id": uid, "wallet": new_my, "rob_last_used": now})).unwrap();
                            let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest { user_id: cmd.user.id.to_string(), username: cmd.user.name.clone(), data_json: data_me }).await;
                            let embed = Self::insp_embed().title("💀 ปล้นไม่สำเร็จ!").description(format!("มึงโดนจับ! จ่ายค่าปรับ **{}** บาทให้เหยื่อ (เหลือ: **{}**)", fine, new_my));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        }
                    }
                }
                "gamble" => {
                    let amount = cmd.data.options.iter().find_map(|o| {
                        if o.name == "amount" { o.value.as_i64() } else { None }
                    }).unwrap_or(0);
                    let uid = cmd.user.id.to_string();
                    let r = self.app.ai.clone().get_economy(GetEconomyRequest { user_id: uid.clone().into() }).await;
                    if let Ok(resp) = r {
                        let data_json = resp.into_inner().data_json;
                        let doc = serde_json::from_str::<serde_json::Value>(&data_json).ok();
                        let wallet = doc.as_ref().and_then(|v| v.get("wallet").and_then(|w| w.as_i64())).unwrap_or(0);
                        let now = Utc::now().timestamp();
                        let last = doc.as_ref().and_then(|v| v.get("gamble_last_used").and_then(|v| v.as_i64())).unwrap_or(0);
                        if now - last < 30 {
                            let left = 30 - (now - last);
                            let embed = Self::insp_embed().title("⏳ ใจเย็น").description(format!("รออีก **{}** วิ", left));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        if amount <= 0 || amount > wallet {
                            let embed = Self::insp_embed().title("❌ ผิดพลาด").description("จำนวนเงินไม่พอหรือไม่ถูกต้อง");
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        let win = (now % 100) < 50;
                        let new_wallet = if win { wallet + amount } else { wallet - amount };
                        let data = serde_json::to_string(&serde_json::json!({
                            "user_id": uid,
                            "wallet": new_wallet,
                            "gamble_last_used": now
                        })).unwrap();
                        let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest {
                            user_id: cmd.user.id.to_string(),
                            username: cmd.user.name.clone(),
                            data_json: data,
                        }).await;
                        if win {
                            let embed = Self::insp_embed().title("🎉 มึงชนะ!").description(format!("ได้เงิน **{}** บาท! (รวม: **{}**)", amount, new_wallet));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        } else {
                            let embed = Self::insp_embed().title("💸 มึงแพ้!").description(format!("เสียเงิน **{}** บาท! (เหลือ: **{}**)", amount, new_wallet));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        }
                    }
                }
                "give" => {
                    let target_user = cmd.data.options.iter().find_map(|o| {
                        if o.name == "target" { o.value.as_user_id() } else { None }
                    });
                    let amount = cmd.data.options.iter().find_map(|o| {
                        if o.name == "amount" { o.value.as_i64() } else { None }
                    }).unwrap_or(0);
                    let uid = cmd.user.id.to_string();
                    if target_user.as_ref().map(|t| t.get()) == Some(cmd.user.id.get()) {
                        let embed = Self::insp_embed().title("❌ ผิดพลาด").description("มึงให้เงินตัวเองทำไมเว้ย");
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                        return;
                    }
                    let Some(target_id) = target_user else {
                        let embed = Self::insp_embed().title("❌ ผิดพลาด").description("ต้องระบุผู้รับ");
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                        return;
                    };
                    let tid = target_id.to_string();
                    let r_me = self.app.ai.clone().get_economy(GetEconomyRequest { user_id: uid.clone().into() }).await;
                    let r_target = self.app.ai.clone().get_economy(GetEconomyRequest { user_id: tid.clone() }).await;
                    if let (Ok(me_resp), Ok(target_resp)) = (r_me, r_target) {
                        let my_wallet = serde_json::from_str::<serde_json::Value>(&me_resp.into_inner().data_json)
                            .ok().and_then(|v| v.get("wallet").and_then(|w| w.as_i64())).unwrap_or(0);
                        let target_wallet = serde_json::from_str::<serde_json::Value>(&target_resp.into_inner().data_json)
                            .ok().and_then(|v| v.get("wallet").and_then(|w| w.as_i64())).unwrap_or(0);
                        let fee = (amount as f64 * 0.1) as i64;
                        let total = amount + fee;
                        if amount <= 0 || total > my_wallet {
                            let embed = Self::insp_embed().title("❌ ผิดพลาด").description("เงินไม่พอ (ต้องจ่ายค่าคอมมิชชั่น 10%)");
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        let new_my = my_wallet - total;
                        let new_target = target_wallet + amount;
                        let data_me = serde_json::to_string(&serde_json::json!({"user_id": uid, "wallet": new_my})).unwrap();
                        let data_target = serde_json::to_string(&serde_json::json!({"user_id": tid, "wallet": new_target})).unwrap();
                        let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest { user_id: cmd.user.id.to_string(), username: cmd.user.name.clone(), data_json: data_me }).await;
                        let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest { user_id: target_id.to_string(), username: target_id.to_string(), data_json: data_target }).await;
                        let embed = Self::insp_embed().title("💸 โอนเงินสำเร็จ").description(format!("โอน **{}** บาทให้ {} (ค่าคอม: **{}**)\nมึงเหลือ: **{}** บาท", amount, target_id.mention(), fee, new_my));
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                    }
                }
                "bribe" => {
                    let uid = cmd.user.id.to_string();
                    let r = self.app.ai.clone().get_economy(GetEconomyRequest { user_id: uid.clone().into() }).await;
                    if let Ok(resp) = r {
                        let data_json = resp.into_inner().data_json;
                        let doc = serde_json::from_str::<serde_json::Value>(&data_json).ok();
                        let wallet = doc.as_ref().and_then(|v| v.get("wallet").and_then(|w| w.as_i64())).unwrap_or(0);
                        let jail_until = doc.as_ref().and_then(|v| v.get("jail_until").and_then(|w| w.as_i64())).unwrap_or(0);
                        let now = Utc::now().timestamp();
                        if jail_until <= now {
                            let embed = Self::insp_embed().title("✅ มึงไม่ติดคุก").description("มึงอยู่ข้างนอกอยู่แล้วเว้ย");
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        let bail = 500;
                        if wallet < bail {
                            let embed = Self::insp_embed().title("❌ เงินไม่พอ").description(format!("ต้องใช้ **{}** บาทเพื่อประกันตัว (มึงมี: **{}**)", bail, wallet));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        let new_wallet = wallet - bail;
                        let data = serde_json::to_string(&serde_json::json!({
                            "user_id": uid,
                            "wallet": new_wallet,
                            "jail_until": now
                        })).unwrap();
                        let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest {
                            user_id: cmd.user.id.to_string(),
                            username: cmd.user.name.clone(),
                            data_json: data,
                        }).await;
                        let embed = Self::insp_embed().title("🔓 ออกจากคุกสำเร็จ!").description(format!("จ่ายสินบน **{}** บาท (เหลือ: **{}**)", bail, new_wallet));
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                    }
                }
                "leaderboard" => {
                    let r = self.app.ai.clone().find_all(FindAllRequest { collection: "economy".into() }).await;
                    if let Ok(resp) = r {
                        let items: Vec<serde_json::Value> = resp.into_inner().items_json.iter().filter_map(|s| serde_json::from_str(s).ok()).collect();
                        let mut sorted: Vec<(String, i64)> = items.into_iter().filter_map(|v| {
                            let uid = v.get("user_id")?.as_str()?.to_string();
                            let wallet = v.get("wallet")?.as_i64()?;
                            Some((uid, wallet))
                        }).collect();
                        sorted.sort_by(|a, b| b.1.cmp(&a.1));
                        let top10: Vec<String> = sorted.iter().take(10).enumerate().map(|(i, (uid, w))| {
                            format!("**#{}.** <@{}> — **{}** บาท", i+1, uid, w)
                        }).collect();
                        let embed = Self::insp_embed()
                            .title("🏆 อันดับคนรวยที่สุดในเซิร์ฟ")
                            .description(if top10.is_empty() { "ยังไม่มีข้อมูล".into() } else { top10.join("\n") });
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                    }
                }
                "shop" => {
                    let items = [
                        ("🗡️ ดาบเหล็ก", 500, "เพิ่มพลังโจมตี +10"),
                        ("🛡️ เกราะหนัง", 400, "เพิ่มพลังป้องกัน +8"),
                        ("💍 แหวนเวท", 600, "เพิ่มพลังเวท +10"),
                        ("🧪 ยาเพิ่มเลเวล", 300, "กินแล้วได้ EXP +100"),
                        ("🍖 เนื้อเสียบไม้", 50, "กินแล้วฟื้น HP 20%"),
                    ];
                    let desc = items.iter().map(|(name, price, desc)| format!("**{}** — **{}** บาท\n> {}", name, price, desc)).collect::<Vec<_>>().join("\n\n");
                    let embed = Self::insp_embed().title("🏪 ร้านค้าวิปปอน").description(format!("{}\n\nใช้ `/buy <ชื่อไอเทม>` เพื่อซื้อ", desc));
                    let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                        CreateInteractionResponseMessage::new().add_embed(embed)
                    )).await;
                }
                "blackmarket" => {
                    let items = [
                        ("🗡️ คาตานะ", 2000, "พลังโจมตี +25 (ของเถื่อน!)"),
                        ("🧪 ยาปลุกเซ็กซ์", 800, "เพิ่มความหื่น +50 (เอ้ย)"),
                        ("📜 คัมภีร์ลับ", 1500, "เพิ่ม EXP +500"),
                        ("💉 สเตียรอยด์", 1000, "เพิ่มทุกสถานะ +5 (เสี่ยงตาย)"),
                    ];
                    let desc = items.iter().map(|(name, price, desc)| format!("**{}** — **{}** บาท\n> {}", name, price, desc)).collect::<Vec<_>>().join("\n\n");
                    let embed = Self::insp_embed().title("🕶️ ตลาดมืด").description(format!("{}\n\nใช้ `/buy <ชื่อไอเทม>` เพื่อซื้อ", desc));
                    let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                        CreateInteractionResponseMessage::new().add_embed(embed)
                    )).await;
                }
                "buy" => {
                    let item_name = cmd.data.options.iter().find_map(|o| {
                        if o.name == "item" { o.value.as_str().map(|s| s.to_string()) } else { None }
                    }).unwrap_or_default();
                    let uid = cmd.user.id.to_string();
                    let r = self.app.ai.clone().get_economy(GetEconomyRequest { user_id: uid.clone().into() }).await;
                    let r_rpg = self.app.ai.clone().get_rpg(GetRpgRequest { user_id: uid.clone() }).await;
                    let prices: HashMap<&str, (i64, &str)> = [
                        ("ดาบเหล็ก", (500, "atk+10")),
                        ("เกราะหนัง", (400, "def+8")),
                        ("แหวนเวท", (600, "mag+10")),
                        ("ยาเพิ่มเลเวล", (300, "exp+100")),
                        ("เนื้อเสียบไม้", (50, "hp+20%")),
                        ("คาตานะ", (2000, "atk+25")),
                        ("ยาปลุกเซ็กซ์", (800, "lewd+50")),
                        ("คัมภีร์ลับ", (1500, "exp+500")),
                        ("สเตียรอยด์", (1000, "all+5")),
                    ].into_iter().collect();
                    if let Some((price, _)) = prices.get(item_name.as_str()) {
                        if let Ok(econ_resp) = r {
                            let wallet = serde_json::from_str::<serde_json::Value>(&econ_resp.into_inner().data_json)
                                .ok().and_then(|v| v.get("wallet").and_then(|w| w.as_i64())).unwrap_or(0);
                            if wallet < *price {
                                let embed = Self::insp_embed().title("❌ เงินไม่พอ").description(format!("ราคา **{}** บาท แต่มึงมีแค่ **{}**", price, wallet));
                                let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                    CreateInteractionResponseMessage::new().add_embed(embed)
                                )).await;
                                return;
                            }
                            let new_wallet = wallet - price;
                            let data = serde_json::to_string(&serde_json::json!({"user_id": uid, "wallet": new_wallet})).unwrap();
                            let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest {
                                user_id: cmd.user.id.to_string(),
                                username: cmd.user.name.clone(),
                                data_json: data,
                            }).await;
                            // Add to inventory in RPG data
                            if let Ok(rpg_resp) = r_rpg {
                                let rpg_json = rpg_resp.into_inner().data_json;
                                let mut rpg_doc: serde_json::Value = serde_json::from_str(&rpg_json).unwrap_or(serde_json::json!({}));
                                let inv = rpg_doc.get_mut("inventory").and_then(|v| v.as_array_mut());
                                if let Some(inv_arr) = inv {
                                    inv_arr.push(serde_json::json!(item_name));
                                } else {
                                    rpg_doc["inventory"] = serde_json::json!([item_name]);
                                }
                                let _ = self.app.ai.clone().upsert_rpg(UpsertRpgRequest {
                                    user_id: cmd.user.id.to_string(),
                                    username: cmd.user.name.clone(),
                                    class: rpg_doc.get("class").and_then(|v| v.as_str()).unwrap_or("").into(),
                                    data_json: serde_json::to_string(&rpg_doc).unwrap(),
                                }).await;
                            }
                            let embed = Self::insp_embed().title("✅ ซื้อสำเร็จ!").description(format!("มึงซื้อ **{}** แล้ว (-**{}** บาท)", item_name, price));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        }
                    } else {
                        let embed = Self::insp_embed().title("❌ ไม่มีไอเทมนี้").description("เช็คชื่อไอเทมให้ถูกต้อง เช็ค /shop และ /blackmarket");
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                    }
                }
                "register" => {
                    let class = cmd.data.options.iter().find_map(|o| {
                        if o.name == "class" { o.value.as_str().map(|s| s.to_string()) } else { None }
                    }).unwrap_or_default();
                    let valid = ["นักรบ", "แม่มด", "โจร"];
                    if !valid.contains(&class.as_str()) {
                        let embed = Self::insp_embed().title("❌ คลาสไม่ถูกต้อง").description("เลือก: นักรบ / แม่มด / โจร");
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                        return;
                    }
                    let uid = cmd.user.id.to_string();
                    let r = self.app.ai.clone().get_rpg(GetRpgRequest { user_id: uid.clone() }).await;
                    if let Ok(resp) = r {
                        let data_json = resp.into_inner().data_json;
                        let doc: serde_json::Value = serde_json::from_str(&data_json).unwrap_or(serde_json::json!({}));
                        if doc.get("class").is_some() {
                            let embed = Self::insp_embed().title("❌ มีตัวละครแล้ว").description("มึงมีตัวละครอยู่แล้วเว้ย");
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                    }
                    let data = serde_json::to_string(&serde_json::json!({
                        "user_id": uid,
                        "class": class,
                        "level": 1,
                        "exp": 0,
                        "hp": 100,
                        "max_hp": 100,
                        "atk": if class == "นักรบ" { 15 } else if class == "แม่มด" { 8 } else { 12 },
                        "def": if class == "นักรบ" { 10 } else if class == "แม่มด" { 5 } else { 8 },
                        "mag": if class == "แม่มด" { 15 } else { 5 },
                        "inventory": [],
                        "equipped": {},
                        "last_hunt": 0,
                        "last_dungeon": 0
                    })).unwrap();
                    let _ = self.app.ai.clone().upsert_rpg(UpsertRpgRequest {
                        user_id: cmd.user.id.to_string(),
                        username: cmd.user.name.clone(),
                        class: class.clone(),
                        data_json: data,
                    }).await;
                    let (atk, def, mag) = match class.as_str() {
                        "นักรบ" => (15, 10, 5),
                        "แม่มด" => (8, 5, 15),
                        _ => (12, 8, 5),
                    };
                    let embed = Self::insp_embed().title("✅ สร้างตัวละครสำเร็จ!").description(format!("คลาส: **{}**\nHP: **100** | ATK: **{}** | DEF: **{}** | MAG: **{}**\nใช้ `/hunt` เพื่อเริ่มผจญภัย!", class, atk, def, mag));
                    let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                        CreateInteractionResponseMessage::new().add_embed(embed)
                    )).await;
                }
                "profile" => {
                    let uid = cmd.user.id.to_string();
                    let r = self.app.ai.clone().get_rpg(GetRpgRequest { user_id: uid }).await;
                    if let Ok(resp) = r {
                        let data_json = resp.into_inner().data_json;
                        let doc: serde_json::Value = serde_json::from_str(&data_json).unwrap_or(serde_json::json!({}));
                        if doc.get("class").is_none() {
                            let embed = Self::insp_embed().title("❌ ยังไม่มีตัวละคร").description("ใช้ `/register` เพื่อสร้างตัวละครก่อน");
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        let class = doc.get("class").and_then(|v| v.as_str()).unwrap_or("?");
                        let level = doc.get("level").and_then(|v| v.as_i64()).unwrap_or(1);
                        let exp = doc.get("exp").and_then(|v| v.as_i64()).unwrap_or(0);
                        let hp = doc.get("hp").and_then(|v| v.as_i64()).unwrap_or(0);
                        let max_hp = doc.get("max_hp").and_then(|v| v.as_i64()).unwrap_or(100);
                        let atk = doc.get("atk").and_then(|v| v.as_i64()).unwrap_or(0);
                        let def = doc.get("def").and_then(|v| v.as_i64()).unwrap_or(0);
                        let mag = doc.get("mag").and_then(|v| v.as_i64()).unwrap_or(0);
                        let inv = doc.get("inventory").and_then(|v| v.as_array()).map(|a| a.len()).unwrap_or(0);
                        let exp_needed = level * 100;
                        let bar_len = 10;
                        let filled = ((exp as f64 / exp_needed as f64) * bar_len as f64) as usize;
                        let exp_bar = format!("[{}{}]", "█".repeat(filled), "░".repeat(bar_len - filled));
                        let embed = Self::insp_embed().title(format!("🧙 ประวัติตัวละคร: {}", cmd.user.name))
                            .description(format!(
                                "**คลาส:** {}\n**เลเวล:** {} | **EXP:** {}/{}\n{}\n**HP:** {}/{}\n**⚔️ ATK:** {} | **🛡️ DEF:** {} | **✨ MAG:** {}\n**🎒 ไอเทมในถุง:** {} ชิ้น",
                                class, level, exp, exp_needed, exp_bar, hp, max_hp, atk, def, mag, inv
                            ));
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                    } else {
                        let embed = Self::insp_embed().title("❌ ยังไม่มีตัวละคร").description("ใช้ `/register` เพื่อสร้างตัวละคร");
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                    }
                }
                "hunt" => {
                    let uid = cmd.user.id.to_string();
                    let now = Utc::now().timestamp();
                    let r = self.app.ai.clone().get_rpg(GetRpgRequest { user_id: uid.clone() }).await;
                    if let Ok(resp) = r {
                        let data_json = resp.into_inner().data_json;
                        let mut doc: serde_json::Value = serde_json::from_str(&data_json).unwrap_or(serde_json::json!({}));
                        if doc.get("class").is_none() {
                            let embed = Self::insp_embed().title("❌ ยังไม่มีตัวละคร").description("ใช้ `/register` ก่อน");
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        let last_hunt = doc.get("last_hunt").and_then(|v| v.as_i64()).unwrap_or(0);
                        if now - last_hunt < 60 {
                            let left = 60 - (now - last_hunt);
                            let embed = Self::insp_embed().title("⏳ ใจเย็น").description(format!("รออีก **{}** วิ ก่อนล่าเจ้าตัวอื่น", left));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        let monsters = [
                            ("🐀 หนูเมือง", 20, 5, 10, 30),
                            ("🦊 จิ้งจอกจอมวายร้าย", 40, 10, 25, 60),
                            ("🧟 ซอมบี้เกรียน", 60, 15, 40, 100),
                            ("🐉 มังกรเหี้ย", 100, 30, 80, 200),
                        ];
                        let (monster, hp, atk, exp_gain, gold_gain) = monsters[(now as usize) % monsters.len()];
                        let my_atk = doc.get("atk").and_then(|v| v.as_i64()).unwrap_or(10);
                        let my_def = doc.get("def").and_then(|v| v.as_i64()).unwrap_or(5);
                        let my_hp = doc.get("hp").and_then(|v| v.as_i64()).unwrap_or(100);
                        let max_hp = doc.get("max_hp").and_then(|v| v.as_i64()).unwrap_or(100);
                        let dmg_taken = (atk - my_def).max(5);
                        let new_hp = (my_hp - dmg_taken).max(0);
                        let win = my_atk >= hp / 2;
                        let new_exp = doc.get("exp").and_then(|v| v.as_i64()).unwrap_or(0) + exp_gain;
                        let level = doc.get("level").and_then(|v| v.as_i64()).unwrap_or(1);
                        let exp_needed = level * 100;
                        if win {
                            let wallet_doc = self.app.ai.clone().get_economy(GetEconomyRequest { user_id: uid.clone() }).await;
                            let wallet = if let Ok(wr) = wallet_doc {
                                serde_json::from_str::<serde_json::Value>(&wr.into_inner().data_json).ok()
                                    .and_then(|v| v.get("wallet").and_then(|w| w.as_i64())).unwrap_or(0)
                            } else { 0 };
                            let new_wallet = wallet + gold_gain;
                            let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest {
                                user_id: cmd.user.id.to_string(),
                                username: cmd.user.name.clone(),
                                data_json: serde_json::to_string(&serde_json::json!({"user_id": uid, "wallet": new_wallet})).unwrap(),
                            }).await;
                            doc["exp"] = serde_json::json!(new_exp);
                            doc["hp"] = serde_json::json!(new_hp);
                            doc["last_hunt"] = serde_json::json!(now);
                            let _ = self.app.ai.clone().upsert_rpg(UpsertRpgRequest {
                                user_id: cmd.user.id.to_string(),
                                username: cmd.user.name.clone(),
                                class: doc.get("class").and_then(|v| v.as_str()).unwrap_or("").into(),
                                data_json: serde_json::to_string(&doc).unwrap(),
                            }).await;
                            let embed = Self::insp_embed().title(format!("⚔️ ล่า{} สำเร็จ!", monster))
                                .description(format!("ชนะ {} ได้ **{}** EXP และ **{}** บาท!\nHP เหลือ: **{}**/{}\nEXP: {}/{}", monster, exp_gain, gold_gain, new_hp, max_hp, new_exp, exp_needed));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        } else {
                            doc["hp"] = serde_json::json!(new_hp);
                            doc["last_hunt"] = serde_json::json!(now);
                            let _ = self.app.ai.clone().upsert_rpg(UpsertRpgRequest {
                                user_id: cmd.user.id.to_string(),
                                username: cmd.user.name.clone(),
                                class: doc.get("class").and_then(|v| v.as_str()).unwrap_or("").into(),
                                data_json: serde_json::to_string(&doc).unwrap(),
                            }).await;
                            let embed = Self::insp_embed().title(format!("💀 แพ้ {}!", monster))
                                .description(format!("มึงตาย! HP เหลือ: **{}**/{}\nรอ 1 นาทีแล้วล่าใหม่อีกละกัน", new_hp, max_hp));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        }
                    }
                }
                "duel" => {
                    let uid = cmd.user.id.to_string();
                    let target_user = cmd.data.options.iter().find_map(|o| {
                        if o.name == "target" { o.value.as_user_id() } else { None }
                    });
                    let bet = cmd.data.options.iter().find_map(|o| {
                        if o.name == "bet" { o.value.as_i64() } else { None }
                    }).unwrap_or(0);
                    if target_user.as_ref().map(|t| t.get()) == Some(cmd.user.id.get()) {
                        let embed = Self::insp_embed().title("❌ ผิดพลาด").description("มึงดวลตัวเองทำไมหรอกเว้ย");
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                        return;
                    }
                    let Some(target_id) = target_user else {
                        let embed = Self::insp_embed().title("❌ ผิดพลาด").description("ต้องระบุคู่ต่อสู้");
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                        return;
                    };
                    let tid = target_id.to_string();
                    let r_me = self.app.ai.clone().get_rpg(GetRpgRequest { user_id: uid.clone() }).await;
                    let r_target = self.app.ai.clone().get_rpg(GetRpgRequest { user_id: tid.clone() }).await;
                    if let (Ok(me_resp), Ok(target_resp)) = (r_me, r_target) {
                        let mut me_doc: serde_json::Value = serde_json::from_str(&me_resp.into_inner().data_json).unwrap_or(serde_json::json!({}));
                        let mut target_doc: serde_json::Value = serde_json::from_str(&target_resp.into_inner().data_json).unwrap_or(serde_json::json!({}));
                        if me_doc.get("class").is_none() || target_doc.get("class").is_none() {
                            let embed = Self::insp_embed().title("❌ ไม่มีตัวละคร").description("ทั้งคู่ต้องมีตัวละครก่อน");
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        let my_wallet = self.app.ai.clone().get_economy(GetEconomyRequest { user_id: uid.clone() }).await;
                        let target_wallet_r = self.app.ai.clone().get_economy(GetEconomyRequest { user_id: tid.clone() }).await;
                        let my_money = my_wallet.ok().and_then(|r| serde_json::from_str::<serde_json::Value>(&r.into_inner().data_json).ok().and_then(|v| v.get("wallet").and_then(|w| w.as_i64()))).unwrap_or(0);
                        let target_money = target_wallet_r.ok().and_then(|r| serde_json::from_str::<serde_json::Value>(&r.into_inner().data_json).ok().and_then(|v| v.get("wallet").and_then(|w| w.as_i64()))).unwrap_or(0);
                        if bet > my_money || bet <= 0 {
                            let embed = Self::insp_embed().title("❌ เงินไม่พอ").description("มึงมีไม่พอที่จะเดิมพัน");
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        let my_atk = me_doc.get("atk").and_then(|v| v.as_i64()).unwrap_or(10);
                        let target_atk = target_doc.get("atk").and_then(|v| v.as_i64()).unwrap_or(10);
                        let my_hp = me_doc.get("hp").and_then(|v| v.as_i64()).unwrap_or(100);
                        let target_hp = target_doc.get("hp").and_then(|v| v.as_i64()).unwrap_or(100);
                        let now = Utc::now().timestamp();
                        let win = (now % 100) < 50;
                        if win {
                            let new_my_money = my_money + bet;
                            let new_target_money = (target_money - bet).max(0);
                            let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest { user_id: cmd.user.id.to_string(), username: cmd.user.name.clone(), data_json: serde_json::to_string(&serde_json::json!({"user_id": uid, "wallet": new_my_money})).unwrap() }).await;
                            let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest { user_id: tid.clone(), username: tid.clone(), data_json: serde_json::to_string(&serde_json::json!({"user_id": tid, "wallet": new_target_money})).unwrap() }).await;
                            me_doc["hp"] = serde_json::json!(my_hp);
                            let _ = self.app.ai.clone().upsert_rpg(UpsertRpgRequest { user_id: cmd.user.id.to_string(), username: cmd.user.name.clone(), class: me_doc.get("class").and_then(|v| v.as_str()).unwrap_or("").into(), data_json: serde_json::to_string(&me_doc).unwrap() }).await;
                            let embed = Self::insp_embed().title("⚔️ มึงชนะดวล!").description(format!("มึงชนะ {} และได้เงินเดิมพัน **{}** บาท!\nHP เหลือ: **{}**", target_id.mention(), bet, my_hp));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        } else {
                            let new_my_money = (my_money - bet).max(0);
                            let new_target_money = target_money + bet;
                            let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest { user_id: cmd.user.id.to_string(), username: cmd.user.name.clone(), data_json: serde_json::to_string(&serde_json::json!({"user_id": uid, "wallet": new_my_money})).unwrap() }).await;
                            let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest { user_id: tid.clone(), username: tid.clone(), data_json: serde_json::to_string(&serde_json::json!({"user_id": tid, "wallet": new_target_money})).unwrap() }).await;
                            target_doc["hp"] = serde_json::json!(target_hp);
                            let _ = self.app.ai.clone().upsert_rpg(UpsertRpgRequest { user_id: tid.clone(), username: tid.clone(), class: target_doc.get("class").and_then(|v| v.as_str()).unwrap_or("").into(), data_json: serde_json::to_string(&target_doc).unwrap() }).await;
                            let embed = Self::insp_embed().title("💀 มึงแพ้ดวล!").description(format!("{} ชนะมึงและเอาเงินเดิมพันไป **{}** บาท!\nHP เหลือ: **{}**", target_id.mention(), bet, my_hp));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        }
                    }
                }
                "dungeon" => {
                    let uid = cmd.user.id.to_string();
                    let now = Utc::now().timestamp();
                    let r = self.app.ai.clone().get_rpg(GetRpgRequest { user_id: uid.clone() }).await;
                    if let Ok(resp) = r {
                        let data_json = resp.into_inner().data_json;
                        let mut doc: serde_json::Value = serde_json::from_str(&data_json).unwrap_or(serde_json::json!({}));
                        if doc.get("class").is_none() {
                            let embed = Self::insp_embed().title("❌ ยังไม่มีตัวละคร").description("ใช้ `/register` ก่อน");
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        let last_dungeon = doc.get("last_dungeon").and_then(|v| v.as_i64()).unwrap_or(0);
                        if now - last_dungeon < 600 {
                            let left = 600 - (now - last_dungeon);
                            let embed = Self::insp_embed().title("⏳ ใจเย็น").description(format!("รออีก **{}** นาที ก่อนเข้าดันเจี้ยน", left / 60));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(CreateInteractionResponseMessage::new().add_embed(embed))).await;
                            return;
                        }
                        let my_atk = doc.get("atk").and_then(|v| v.as_i64()).unwrap_or(10);
                        let my_def = doc.get("def").and_then(|v| v.as_i64()).unwrap_or(5);
                        let my_hp = doc.get("hp").and_then(|v| v.as_i64()).unwrap_or(100);
                        let max_hp = doc.get("max_hp").and_then(|v| v.as_i64()).unwrap_or(100);
                        let dmg_taken = (80 - my_def).max(10);
                        let new_hp = (my_hp - dmg_taken).max(0);
                        let exp_gain = 200;
                        let gold_gain = 300;
                        let new_exp = doc.get("exp").and_then(|v| v.as_i64()).unwrap_or(0) + exp_gain;
                        let win = my_atk >= 40;
                        if win {
                            let wallet_doc = self.app.ai.clone().get_economy(GetEconomyRequest { user_id: uid.clone() }).await;
                            let wallet = if let Ok(wr) = wallet_doc {
                                serde_json::from_str::<serde_json::Value>(&wr.into_inner().data_json).ok()
                                    .and_then(|v| v.get("wallet").and_then(|w| w.as_i64())).unwrap_or(0)
                            } else { 0 };
                            let new_wallet = wallet + gold_gain;
                            let _ = self.app.ai.clone().upsert_economy(UpsertEconomyRequest {
                                user_id: cmd.user.id.to_string(), username: cmd.user.name.clone(),
                                data_json: serde_json::to_string(&serde_json::json!({"user_id": uid, "wallet": new_wallet})).unwrap(),
                            }).await;
                            doc["exp"] = serde_json::json!(new_exp);
                            doc["hp"] = serde_json::json!(new_hp);
                            doc["last_dungeon"] = serde_json::json!(now);
                            let _ = self.app.ai.clone().upsert_rpg(UpsertRpgRequest {
                                user_id: cmd.user.id.to_string(), username: cmd.user.name.clone(),
                                class: doc.get("class").and_then(|v| v.as_str()).unwrap_or("").into(),
                                data_json: serde_json::to_string(&doc).unwrap(),
                            }).await;
                            let embed = Self::insp_embed().title("🏰 ผ่านดันเจี้ยน!").description(format!("บุกตะลุยดันเจี้ยนสำเร็จ! ได้ **{}** EXP และ **{}** บาท!\nHP เหลือ: **{}**/{}", exp_gain, gold_gain, new_hp, max_hp));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        } else {
                            doc["hp"] = serde_json::json!(new_hp);
                            doc["last_dungeon"] = serde_json::json!(now);
                            let _ = self.app.ai.clone().upsert_rpg(UpsertRpgRequest {
                                user_id: cmd.user.id.to_string(), username: cmd.user.name.clone(),
                                class: doc.get("class").and_then(|v| v.as_str()).unwrap_or("").into(),
                                data_json: serde_json::to_string(&doc).unwrap(),
                            }).await;
                            let embed = Self::insp_embed().title("💀 แพ้ดันเจี้ยน!").description(format!("บอสแม่งโหดเกินไป! HP เหลือ: **{}**/{}", new_hp, max_hp));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                        }
                    }
                }
                "inventory" => {
                    let uid = cmd.user.id.to_string();
                    let r = self.app.ai.clone().get_rpg(GetRpgRequest { user_id: uid }).await;
                    if let Ok(resp) = r {
                        let data_json = resp.into_inner().data_json;
                        let doc: serde_json::Value = serde_json::from_str(&data_json).unwrap_or(serde_json::json!({}));
                        let inv = doc.get("inventory").and_then(|v| v.as_array()).map(|a| a.iter().map(|i| i.as_str().unwrap_or("?")).collect::<Vec<_>>()).unwrap_or_default();
                        let equipped = doc.get("equipped").and_then(|v| v.as_object()).map(|o| {
                            o.iter().map(|(k, v)| format!("{}: **{}**", k, v.as_str().unwrap_or("?"))).collect::<Vec<_>>()
                        }).unwrap_or_default();
                        let desc = if inv.is_empty() {
                            "ถุงยังว่างเปล่า ไปซื้อของสิที่ /shop".into()
                        } else {
                            format!("**ไอเทมในถุง:**\n{}\n\n**ไอเทมที่สวมใส่:**\n{}", inv.join("\n"), if equipped.is_empty() { "ยังไม่มี".into() } else { equipped.join("\n") })
                        };
                        let embed = Self::insp_embed().title("🎒 ถุงของมึง").description(desc);
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                    }
                }
                "equip" => {
                    let item_name = cmd.data.options.iter().find_map(|o| {
                        if o.name == "item" { o.value.as_str().map(|s| s.to_string()) } else { None }
                    }).unwrap_or_default();
                    let uid = cmd.user.id.to_string();
                    let r = self.app.ai.clone().get_rpg(GetRpgRequest { user_id: uid.clone() }).await;
                    if let Ok(resp) = r {
                        let data_json = resp.into_inner().data_json;
                        let mut doc: serde_json::Value = serde_json::from_str(&data_json).unwrap_or(serde_json::json!({}));
                        let inv = doc.get_mut("inventory").and_then(|v| v.as_array_mut());
                        let found = if let Some(arr) = inv {
                            arr.iter().position(|i| i.as_str() == Some(item_name.as_str()))
                        } else { None };
                        if found.is_none() {
                            let embed = Self::insp_embed().title("❌ ไม่มีไอเทมนี้").description("เช็ค /inventory ก่อน");
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        // Equip: remove from inventory, add to equipped
                        if let Some(arr) = doc.get_mut("inventory").and_then(|v| v.as_array_mut()) {
                            arr.remove(found.unwrap());
                        }
                        let stat_boosts: HashMap<&str, (&str, i64)> = [
                            ("ดาบเหล็ก", ("atk", 10)),
                            ("เกราะหนัง", ("def", 8)),
                            ("แหวนเวท", ("mag", 10)),
                            ("คาตานะ", ("atk", 25)),
                            ("ยาปลุกเซ็กซ์", ("lewd", 50)),
                            ("สเตียรอยด์", ("all", 5)),
                        ].into_iter().collect();
                        if let Some((stat, boost)) = stat_boosts.get(item_name.as_str()) {
                            if *stat == "all" {
                                for s in ["atk", "def", "mag"] {
                                    *doc.get_mut(s).unwrap_or(&mut serde_json::json!(0)) = serde_json::json!(doc.get(s).and_then(|v| v.as_i64()).unwrap_or(0) + boost);
                                }
                            } else {
                                *doc.get_mut(stat).unwrap_or(&mut serde_json::json!(0)) = serde_json::json!(doc.get(stat).and_then(|v| v.as_i64()).unwrap_or(0) + boost);
                            }
                        }
                        let mut default_equip = serde_json::json!({});
                        let equipped = doc.get_mut("equipped").unwrap_or(&mut default_equip);
                        if let Some(eq) = equipped.as_object_mut() {
                            eq.insert("main_hand".into(), serde_json::json!(item_name));
                        }
                        let _ = self.app.ai.clone().upsert_rpg(UpsertRpgRequest {
                            user_id: cmd.user.id.to_string(),
                            username: cmd.user.name.clone(),
                            class: doc.get("class").and_then(|v| v.as_str()).unwrap_or("").into(),
                            data_json: serde_json::to_string(&doc).unwrap(),
                        }).await;
                        let embed = Self::insp_embed().title("✅ สวมใส่สำเร็จ!").description(format!("มึงสวมใส่ **{}** แล้ว!", item_name));
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                    }
                }
                "levelup" => {
                    let uid = cmd.user.id.to_string();
                    let r = self.app.ai.clone().get_rpg(GetRpgRequest { user_id: uid }).await;
                    if let Ok(resp) = r {
                        let data_json = resp.into_inner().data_json;
                        let mut doc: serde_json::Value = serde_json::from_str(&data_json).unwrap_or(serde_json::json!({}));
                        let level = doc.get("level").and_then(|v| v.as_i64()).unwrap_or(1);
                        let exp = doc.get("exp").and_then(|v| v.as_i64()).unwrap_or(0);
                        let exp_needed = level * 100;
                        if exp < exp_needed {
                            let embed = Self::insp_embed().title("❌ EXP ไม่พอ").description(format!("ต้องการ {} EXP (มี: {})", exp_needed, exp));
                            let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                                CreateInteractionResponseMessage::new().add_embed(embed)
                            )).await;
                            return;
                        }
                        doc["level"] = serde_json::json!(level + 1);
                        doc["exp"] = serde_json::json!(exp - exp_needed);
                        doc["atk"] = serde_json::json!(doc.get("atk").and_then(|v| v.as_i64()).unwrap_or(10) + 5);
                        doc["def"] = serde_json::json!(doc.get("def").and_then(|v| v.as_i64()).unwrap_or(5) + 5);
                        doc["mag"] = serde_json::json!(doc.get("mag").and_then(|v| v.as_i64()).unwrap_or(5) + 5);
                        doc["max_hp"] = serde_json::json!(doc.get("max_hp").and_then(|v| v.as_i64()).unwrap_or(100) + 20);
                        doc["hp"] = serde_json::json!(doc.get("max_hp").and_then(|v| v.as_i64()).unwrap_or(100));
                        let _ = self.app.ai.clone().upsert_rpg(UpsertRpgRequest {
                            user_id: cmd.user.id.to_string(),
                            username: cmd.user.name.clone(),
                            class: doc.get("class").and_then(|v| v.as_str()).unwrap_or("").into(),
                            data_json: serde_json::to_string(&doc).unwrap(),
                        }).await;
                        let embed = Self::insp_embed().title("⬆️ เลเวลอัพ!").description(format!("เลเวล {} → {}!\n+5 ATK, +5 DEF, +5 MAG, +20 Max HP", level, level+1));
                        let _ = cmd.create_response(&ctx.http, CreateInteractionResponse::Message(
                            CreateInteractionResponseMessage::new().add_embed(embed)
                        )).await;
                    }
                }
                _ => {}
            }
        }
    }

    async fn ready(&self, ctx: Context, ready: Ready) {
        println!("👮 [{}] {} ออนไลน์!", self.bot_name, ready.user.name);

        // Register slash commands
        let commands = vec![
            CreateCommand::new("balance").description("ดูเงินในกระเป๋าและอันดับ"),
            CreateCommand::new("work").description("ทำงานหาเงิน"),
            CreateCommand::new("crime").description("ก่ออาชญากรรมเสี่ยงโชค"),
            CreateCommand::new("rob").description("ปล้นเงินผู้เล่นคนอื่น").add_option(
                CreateCommandOption::new(CommandOptionType::User, "target", "ผู้เล่นที่จะปล้น").required(true)
            ).add_option(
                CreateCommandOption::new(CommandOptionType::Integer, "amount", "จำนวนเงินที่จะปล้น").required(false)
            ),
            CreateCommand::new("gamble").description("พนันด้วยลูกเต๋า").add_option(
                CreateCommandOption::new(CommandOptionType::Integer, "amount", "จำนวนเงินที่จะพนัน").required(true)
            ),
            CreateCommand::new("give").description("โอนเงินให้คนอื่น").add_option(
                CreateCommandOption::new(CommandOptionType::User, "target", "ผู้รับเงิน").required(true)
            ).add_option(
                CreateCommandOption::new(CommandOptionType::Integer, "amount", "จำนวนเงิน").required(true)
            ),
            CreateCommand::new("bribe").description("จ่ายสินบนเพื่อออกจากคุก"),
            CreateCommand::new("leaderboard").description("อันดับคนรวยที่สุดในเซิร์ฟ"),
            CreateCommand::new("shop").description("ร้านค้าวิปปอน"),
            CreateCommand::new("blackmarket").description("ตลาดมืด"),
            CreateCommand::new("buy").description("ซื้อไอเทม").add_option(
                CreateCommandOption::new(CommandOptionType::String, "item", "ชื่อไอเทม").required(true)
            ),
            CreateCommand::new("register").description("สร้างตัวละคร").add_option(
                CreateCommandOption::new(CommandOptionType::String, "class", "คลาส: นักรบ/แม่มด/โจร").required(true)
            ),
            CreateCommand::new("profile").description("ดูสถานะตัวละคร"),
            CreateCommand::new("hunt").description("ล่ามอนสเตอร์"),
            CreateCommand::new("duel").description("ดวล์ 1v1").add_option(
                CreateCommandOption::new(CommandOptionType::User, "target", "คู่ต่อสู้").required(true)
            ).add_option(
                CreateCommandOption::new(CommandOptionType::Integer, "bet", "เงินเดิมพัน").required(true)
            ),
            CreateCommand::new("dungeon").description("เข้าดันเจี้ยน"),
            CreateCommand::new("inventory").description("ดูไอเทมในถุง"),
            CreateCommand::new("equip").description("สวมใส่ไอเทม").add_option(
                CreateCommandOption::new(CommandOptionType::String, "item", "ชื่อไอเทม").required(true)
            ),
            CreateCommand::new("levelup").description("อัพเลเวล"),
        ];
        for cmd in commands {
            if let Err(e) = Command::create_global_command(&ctx.http, cmd).await {
                eprintln!("Failed to register command: {}", e);
            }
        }
    }
}

// ---------------------------------------------------------------------------
// Main
// ---------------------------------------------------------------------------

async fn spawn_bot(
    token_key: &'static str,
    handler: impl EventHandler + 'static,
    intents: GatewayIntents,
) {
    let token_key_owned = token_key.to_string();
    let token = match env::var(token_key) {
        Ok(t) => t,
        Err(_) => {
            eprintln!("❌ {} not set, skipping this bot", token_key_owned);
            return;
        }
    };
    tokio::spawn(async move {
        let mut client = match DiscordClient::builder(&token, intents)
            .event_handler(handler)
            .await
        {
            Ok(c) => c,
            Err(e) => {
                eprintln!("❌ {} failed to create client: {:?}", token_key_owned, e);
                return;
            }
        };
        if let Err(e) = client.start().await {
            eprintln!("❌ {} failed to start: {:?}", token_key_owned, e);
        }
    });
}

#[tokio::main]
async fn main() -> anyhow::Result<()> {
    dotenvy::dotenv().ok();

    let ai_addr = env::var("BOT_MESSAGING_ADDR")
        .unwrap_or_else(|_| "http://0.0.0.0:50052".into());

    let mut ai = None;
    for i in 1..=10 {
        match BotMessagingClient::connect(ai_addr.clone()).await {
            Ok(client) => { ai = Some(client); break; }
            Err(e) => {
                eprintln!("Attempt {}: Failed to connect to ai-core: {}. Retrying...", i, e);
                tokio::time::sleep(std::time::Duration::from_secs(2)).await;
            }
        }
    }
    let ai = ai.ok_or_else(|| anyhow::anyhow!("Failed to connect to ai-core after 10 attempts"))?;

    let app_state = Arc::new(AppState {
        ai,
        active_task: Arc::new(Mutex::new(None)),
    });

    let intents = GatewayIntents::GUILDS
        | GatewayIntents::GUILD_MESSAGES
        | GatewayIntents::MESSAGE_CONTENT
        | GatewayIntents::GUILD_MEMBERS;

    let mod_intents = intents | GatewayIntents::GUILD_MODERATION;
    let welcome_intents = GatewayIntents::GUILD_MEMBERS | GatewayIntents::GUILDS;

    spawn_bot(
        "DISCORD_BOT_TOKEN_TAH",
        AiDiscordHandler {
            bot_name: "ต๊ะ".into(),
            channel_id: 1490026273408291128,
            prompt: TAH_PROMPT,
            db_prefix: "tah_ds".into(),
            app: app_state.clone(),
        },
        intents,
    ).await;

    spawn_bot(
        "DISCORD_BOT_TOKEN_wang",
        AiDiscordHandler {
            bot_name: "อาวัง".into(),
            channel_id: 1491083921687843086,
            prompt: WANG_PROMPT,
            db_prefix: "wang".into(),
            app: app_state.clone(),
        },
        intents,
    ).await;

    spawn_bot(
        "DISCORD_BOT_TOKEN_mung",
        AiDiscordHandler {
            bot_name: "เจ๊มุ่ง".into(),
            channel_id: 1491324375549612112,
            prompt: MUNG_PROMPT,
            db_prefix: "mung".into(),
            app: app_state.clone(),
        },
        intents,
    ).await;

    spawn_bot(
        "DISCORD_BOT_TOKEN_judge",
        JudgeHandler {
            app: app_state.clone(),
            bot_name: "ผู้คุมกฎ".into(),
        },
        intents,
    ).await;

    spawn_bot(
        "DISCORD_BOT_TOKEN_mod",
        ModHandler {
            app: app_state.clone(),
            bot_name: "มอด".into(),
        },
        mod_intents,
    ).await;

    spawn_bot(
        "DISCORD_BOT_TOKEN_nutin",
        AiDiscordHandler {
            bot_name: "เสี่ยหนู".into(),
            channel_id: 1494711329611714711,
            prompt: NUTIN_PROMPT,
            db_prefix: "nutin".into(),
            app: app_state.clone(),
        },
        intents,
    ).await;

    spawn_bot(
        "DISCORD_BOT_TOKEN_johan",
        AiDiscordHandler {
            bot_name: "โยฮัน".into(),
            channel_id: 1497986632089997545,
            prompt: JOHAN_PROMPT,
            db_prefix: "johan".into(),
            app: app_state.clone(),
        },
        intents,
    ).await;

    spawn_bot(
        "DISCORD_BOT_TOKEN_inspector",
        InspectorHandler {
            app: app_state.clone(),
            bot_name: "สารวัตรแจ๊ะ",
        },
        intents,
    ).await;

    spawn_bot(
        "DISCORD_BOT_TOKEN_welcomebot",
        WelcomeHandler,
        welcome_intents,
    ).await;

    println!("🚀 gateway-discord running. All bots online.");
    tokio::signal::ctrl_c().await?;
    Ok(())
}
